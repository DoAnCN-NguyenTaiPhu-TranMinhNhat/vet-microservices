# Spring PetClinic Microservices Environment Variables

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=petclinic
POSTGRES_USER=petclinic
POSTGRES_PASSWORD=petclinic

# Config Server
CONFIG_SERVER_URL=http://localhost:8888
SPRING_PROFILES_ACTIVE=docker

# AI Service Integration
VETAI_DIAGNOSIS_URL=http://localhost:8000
GENAI_SERVICE_URL=http://localhost:8090

# Continuous Training
CONTINUOUS_TRAINING_ENABLED=true
CONTINUOUS_TRAINING_THRESHOLD=100
CONTINUOUS_TRAINING_WINDOW_DAYS=30

# Monitoring
ENABLE_METRICS=true
GRAFANA_PORT=3030
PROMETHEUS_PORT=9091

# Feature Flags
ENABLE_AI_DIAGNOSIS=false
ENABLE_SHAP_EXPLANATIONS=false
ENABLE_CONTINUOUS_TRAINING=false

# Logging
LOG_LEVEL=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SAMPLES_PETCLINIC=INFO
