# vet-microservices — environment template
#
# Docker Compose in this repo loads ../vet-infra/.env for vet-ai / genai-service.
# Copy this file to .env.local (gitignored) or merge entries into vet-infra/.env as needed.
#
# Spring services resolve CONFIG_SERVER_URL (see each module application.yml spring.config.import).

# -----------------------------------------------------------------------------
# Option A — URLs when Spring Boot runs ON THE HOST (IDE) and infra is on localhost
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker
LOGGING_LEVEL_ROOT=INFO

CONFIG_SERVER_URL=http://localhost:8888/
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://localhost:8761/eureka

VETAI_DIAGNOSIS_URL=http://localhost:8000
GENAI_SERVICE_URL=http://localhost:8090
VETAI_UID=1000
VETAI_GID=1000
MLAIR_API_BASE_URL=http://localhost:8080
MLAIR_TENANT_ID=default
MLAIR_PROJECT_ID=default_project
MLAIR_PIPELINE_ID=vet_ai_training_pipeline
MLAIR_MODEL_NAME=vet-ai
MLAIR_MODEL_DESCRIPTION=Synced from Vet-AI model store
MLAIR_MODEL_STAGE=staging
VETAI_MLAIR_SYNC_MODELS_ON_STARTUP=true
# Backward-compatible alias (deprecated):
MLAIR_SYNC_MODELS_ON_STARTUP=true
MLAIR_MODEL_SCOPE_PER_CLINIC=true
MLAIR_CLINIC_MODEL_ALIAS_MAP_JSON={}
MLAIR_CLINIC_PROJECT_MAP_JSON={}
MLAIR_CLINIC_TENANT_MAP_JSON={}
MLAIR_AUTO_TRIGGER_ENABLED=false
MLAIR_IMAGE_TAG=latest
ML_AIR_API_PORT=8080
ML_AIR_FRONTEND_PORT=38080
ML_AIR_POSTGRES_USER=mlair
ML_AIR_POSTGRES_PASSWORD=mlair
ML_AIR_POSTGRES_DB=mlair

JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional: Circuit breaker (Resilience4j — if wired via config repo)
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_DEFAULT_SLIDINGWINDOWTYPE=COUNT_BASED
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_DEFAULT_SLIDINGWINDOWSIZE=10
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_DEFAULT_FAILURERATE=50

# Optional: Actuator / Prometheus
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# Optional: Zipkin
SPRING_SLEUTH_ZIPKIN_BASE_URL=http://localhost:9411

# -----------------------------------------------------------------------------
# Option B — same keys using Docker Compose *service DNS* (containers on petclinic-net)
# Use when passing this file as env_file to a custom override, not for host-run JVM.
# -----------------------------------------------------------------------------
# CONFIG_SERVER_URL=http://config-server:8888/
# EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://discovery-server:8761/eureka
# VETAI_DIAGNOSIS_URL=http://vet-ai:8000
# SPRING_SLEUTH_ZIPKIN_BASE_URL=http://tracing-server:9411

# -----------------------------------------------------------------------------
# Optional — JDBC when using spring profile postgresql / external DB (not default HSQL in compose)
# -----------------------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=petclinic
# POSTGRES_USER=petclinic
# POSTGRES_PASSWORD=petclinic
