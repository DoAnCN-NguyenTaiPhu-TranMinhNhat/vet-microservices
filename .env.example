# =============================================================================
# vet-microservices — environment template (single `.env` next to docker-compose.yml)
# =============================================================================
# Copy:   cp .env.example .env
# Compose reads `.env` for ${VAR} substitution; the same file is `env_file` for vet-ai,
# genai-service, vet-ai-training (after optional ../vet-infra/.env when present).
#
# MLAir services use Compose profile `mlair`. Enable with:
#   COMPOSE_PROFILES=mlair
# Or:    docker compose --profile mlair up -d

# =============================================================================
# 1. Compose
# =============================================================================
COMPOSE_PROFILES=mlair

# =============================================================================
# 2. Spring Boot (petclinic-net — default for full stack in Docker)
# =============================================================================
SPRING_PROFILES_ACTIVE=docker
LOGGING_LEVEL_ROOT=INFO

CONFIG_SERVER_URL=http://config-server:8888/
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://discovery-server:8761/eureka
VETAI_DIAGNOSIS_URL=http://vet-ai:8000
GENAI_SERVICE_URL=http://genai-service:8090

JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ADMIN_TOKEN=admin-secret

VETAI_UID=1000
VETAI_GID=1000

# Optional: Resilience4j / Actuator / Zipkin
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_DEFAULT_SLIDINGWINDOWTYPE=COUNT_BASED
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_DEFAULT_SLIDINGWINDOWSIZE=10
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_DEFAULT_FAILURERATE=50
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
SPRING_SLEUTH_ZIPKIN_BASE_URL=http://tracing-server:9411

# =============================================================================
# 3. Vet-AI (container) — database, customers, MLAir client
# =============================================================================
DATABASE_URL=postgresql://mlflow:mlflow@postgres:5432/mlflow

# Clinic catalog for MLOps + MLAir project registry (must match code: clinic_catalog_service)
CUSTOMERS_SERVICE_BASE_URL=http://customers-service:8081
CUSTOMERS_CLINICS_PATH=/clinics
CUSTOMERS_SERVICE_TIMEOUT_SECONDS=5
CUSTOMERS_CLINICS_CACHE_TTL_SECONDS=60

# MLAir client (vet-ai). When MLAIR_API_BASE_URL is set, training imports registry + vet-ai
# POSTs tenant_projects via /v1/tenants/{tenant}/projects/registry (MLAir migration 0020+).
MLAIR_API_BASE_URL=http://mlair-api:8080
MLAIR_API_TOKEN=admin-token
MLAIR_TENANT_ID=default
MLAIR_PROJECT_GLOBAL=default_project
MLAIR_PROJECT_CLINIC_PREFIX=clinic_
MLAIR_MODEL_NAME_GLOBAL=vetai-diagnosis-global
MLAIR_MODEL_NAME_CLINIC_PREFIX=vetai-diagnosis-clinic
MLAIR_IMPORT_STAGE=staging
MLAIR_DISK_MODEL_IMPORT_AT_REGISTRY=1
# MLAIR_DISK_IMPORT_CLINIC_FALLBACK_GLOBAL=0
MLAIR_TIMEOUT_SECONDS=120
# When Vet-AI pins active model → MLAir POST .../promote (set 0 to disable).
# MLAIR_SYNC_APPROVE_BEFORE_PROMOTE=1
# MLAIR_PROMOTE_WEBHOOK_INBOUND_TOKEN=change-me
# On mlair-api: MLAIR_MODEL_PROMOTE_WEBHOOK_URL=http://vet-ai:8000/mlops/mlair/promote-webhook
# MLAIR_MODEL_PROMOTE_WEBHOOK_BEARER_TOKEN=change-me (same value as MLAIR_PROMOTE_WEBHOOK_INBOUND_TOKEN)
# Real PyTorch training on Vet-AI (same rules as POST /training/trigger): POST http://vet-ai:8000/mlops/mlair/training-invoke
# Body: {"project_id":"clinic_<id>|default_project","force":true}  Header: Authorization: Bearer <token>
# MLAIR_TRAINING_INVOKE_TOKEN=change-me

# Executor → Vet-AI training adapter (real task execution)
# VETAI_TRAINING_INVOKE_URL=http://vet-ai:8000/mlops/mlair/training-invoke
# VETAI_TRAINING_POLL_SECONDS=5
# VETAI_TRAINING_MAX_WAIT_SECONDS=3600

# Registry bootstrap (vet-ai startup + periodic; see mlair_client / main lifespan)
MLAIR_REGISTRY_SYNC_AT_STARTUP=1
MLAIR_REGISTRY_BUST_CLINIC_CACHE=1
MLAIR_REGISTRY_BOOTSTRAP_MAX_WAIT_SECONDS=120
MLAIR_REGISTRY_BOOTSTRAP_INTERVAL_SECONDS=5
MLAIR_REGISTRY_RESYNC_SECONDS=120
# MLAIR_REGISTRY_GLOBAL_PROJECT_NAME=Vet-AI (global)
# MLAIR_REGISTRY_SYNC_AT_STARTUP=0
# MLAIR_REGISTRY_RESYNC_SECONDS=0

# Pipeline “thật” (plugin MLAir: app_etl_adapter, echo_tracking) + run tùy chọn — giống ml-air/scripts/seed_demo.py
# MLAIR_SEED_DEMO_EXECUTOR=1
# Tắt auto-run demo (fail_once_demo…): MLAIR_SEED_DEMO_EXECUTOR_RUN=0 — train PyTorch dùng Vet-AI /mlops/mlair/training-invoke
# MLAIR_SEED_DEMO_EXECUTOR_RUN=1
# MLAIR_SEED_PIPELINE_ID=vetai_train_pipeline
# MLAIR_SEED_DEMO_EXECUTOR_PROJECTS=default_project
# MLAIR_SEED_PIPELINE_CONFIG_JSON={"tasks":[...]}
# Chỉ placeholder pipeline rỗng (không plugin): MLAIR_STUB_PIPELINE_AT_REGISTRY=1
# MLAIR_TRAINING_TRACKING=1
# MLAIR_TRACKING_PIPELINE_ID=vetai_local_training
# MLAIR_TRACKING_POLL_SECONDS=90
#
# Feedback → MLAir buffer (per project: default_project vs clinic_*; dataset MLAIR_FEEDBACK_DATASET_NAME)
MLAIR_FEEDBACK_BUFFER_SYNC=1
MLAIR_FEEDBACK_DATASET_NAME=vetai_runtime_feedback
MLAIR_FEEDBACK_TARGET_THRESHOLD=1000
MLAIR_FEEDBACK_ACCUMULATION_STRATEGY=snapshot_on_threshold
# MLAIR_FEEDBACK_SINK_PIPELINE_ID=vetai_train_pipeline
MLAIR_FEEDBACK_SINK_PLUGIN=echo_tracking

# Optional static clinic list (JSON array of {id,name}) merged with customers-service
# MLOPS_CLINICS_JSON=

# =============================================================================
# 4. MLAir stack (Compose profile mlair) — images & published ports
# =============================================================================
# Images: ghcr.io/<owner>/ml-air-{api,scheduler,executor,frontend}
MLAIR_IMAGE_OWNER=phu142857
MLAIR_IMAGE_TAG=latest
MLAIR_PULL_POLICY=always

MLAIR_POSTGRES_USER=mlair
MLAIR_POSTGRES_PASSWORD=mlair
MLAIR_POSTGRES_DB=mlair

MLAIR_API_HOST_PORT=18080
MLAIR_FRONTEND_HOST_PORT=38080
MLAIR_REDIS_HOST_PORT=16379
MLAIR_POSTGRES_HOST_PORT=15432

# Browser: open http://<host>:MLAIR_FRONTEND_HOST_PORT (mlair-browser-gateway). It proxies / → Next UI and
# /v1 → mlair-api so dataset upload is same-origin. ./mlair/mlair-runtime-config.js sets api_base_url
# to window.location.origin. MLAIR_API_HOST_PORT stays published for curl / host-side tools; vet-ai uses
# MLAIR_API_BASE_URL=http://mlair-api:8080 inside Compose.
#
# Dataset upload DB default for materialized_from_buffer is re-applied on every mlair-api start
# (see docker-compose.yml). Manual SQL if needed: ./mlair/sql/fix_dataset_versions_materialized_default.sql

# Optional overrides passed into mlair-api / executor (compose interpolates these)
# Model registry files live under ML_AIR_DEFAULT_MODEL_ARTIFACT_ROOT on the mlair-api container.
# Compose mounts a named volume at /mlair/artifacts/models (see docker-compose.yml); vet-ai uses
# MODEL_ROOT_DIR=/app/ai_service/models — that is a different container; do not expect MLAir to
# read vet-ai paths unless you add a shared bind mount yourself.
# ML_AIR_DEFAULT_MODEL_ARTIFACT_ROOT=file:///mlair/artifacts/models
# ML_AIR_DATASET_ARTIFACT_ROOT=file:///mlair/artifacts/datasets
# ML_AIR_JWT_HS256_SECRET=
# ML_AIR_TRACKING_TOKEN=admin-token
# ML_AIR_MANIFEST_SIGNING_KEY=
# MLAIR_REALTIME_ENABLED=false
# MLAIR_MODEL_PROMOTE_WEBHOOK_URL=
# MLAIR_MODEL_PROMOTE_WEBHOOK_BEARER_TOKEN=

# =============================================================================
# 5. Optional — Spring on the host (IDE) with infra on localhost (uncomment to use)
# =============================================================================
# CONFIG_SERVER_URL=http://localhost:8888/
# EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://localhost:8761/eureka
# VETAI_DIAGNOSIS_URL=http://localhost:8000
# GENAI_SERVICE_URL=http://localhost:8090
# SPRING_SLEUTH_ZIPKIN_BASE_URL=http://localhost:9411

# =============================================================================
# 6. Optional — external JDBC (postgresql profile)
# =============================================================================
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=petclinic
# POSTGRES_USER=petclinic
# POSTGRES_PASSWORD=petclinic
